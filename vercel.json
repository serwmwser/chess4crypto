{
    "version": 2,
    "github": {
      "silent": false,
      "autoJobCancelation": true,
      "enabled": true
    },
    "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
    "outputDirectory": "frontend/dist",
    "installCommand": "cd frontend && npm install --legacy-peer-deps",
    "framework": "vite",
    "rewrites": [
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ],
    "env": {
      "NODE_VERSION": "18"
    }
  }