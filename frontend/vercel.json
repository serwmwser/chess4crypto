{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NPM_FLAGS": "--legacy-peer-deps"
  },
  "build": {
    "env": {
      "NODE_VERSION": "24"
    }
  }
}